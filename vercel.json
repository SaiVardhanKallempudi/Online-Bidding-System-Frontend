{
  "redirects": [
    {
      "source": "/",
      "destination": "https://bidmart.me/",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.bidmart.me"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}